#include <iostream>
#include <fstream>
#include <string>

using namespace std;

class Task
{
public:
    string subject;
    string chapter;
    string examDate;
    bool completed;
};

Task tasks[100];
int taskCount = 0;

void saveTasks()
{
    ofstream file("tasks.txt");

    file << taskCount << endl;

    for(int i = 0; i < taskCount; i++)
    {
        file << tasks[i].subject << endl;
        file << tasks[i].chapter << endl;
        file << tasks[i].examDate << endl;
        file << tasks[i].completed << endl;
    }

    file.close();
}

void loadTasks()
{
    ifstream file("tasks.txt");

    if(!file)
        return;

    file >> taskCount;
    file.ignore();

    for(int i = 0; i < taskCount; i++)
    {
        getline(file, tasks[i].subject);
        getline(file, tasks[i].chapter);
        getline(file, tasks[i].examDate);
        file >> tasks[i].completed;
        file.ignore();
    }

    file.close();
}

void addTask()
{
    if(taskCount >= 100)
    {
        cout << "\nTask Limit Reached\n";
        return;
    }

    cout << "\nEnter Subject: ";
    cin.ignore();
    getline(cin, tasks[taskCount].subject);

    cout << "Enter Chapter: ";
    getline(cin, tasks[taskCount].chapter);

    cout << "Enter Exam Date: ";
    getline(cin, tasks[taskCount].examDate);

    tasks[taskCount].completed = false;
    taskCount++;

    saveTasks();

    cout << "\nTask Added Successfully\n";
}

void viewTasks()
{
    if(taskCount == 0)
    {
        cout << "\nNo Tasks Available\n";
        return;
    }

    cout << "\n========== TASK LIST ==========\n";

    for(int i = 0; i < taskCount; i++)
    {
        cout << "\nTask " << i + 1 << endl;
        cout << "Subject : " << tasks[i].subject << endl;
        cout << "Chapter : " << tasks[i].chapter << endl;
        cout << "Exam Date : " << tasks[i].examDate << endl;
        cout << "Status : ";

        if(tasks[i].completed)
            cout << "Completed";
        else
            cout << "Pending";

        cout << endl;
    }
}

void markCompleted()
{
    int num;

    viewTasks();

    cout << "\nEnter Task Number: ";
    cin >> num;

    if(num < 1 || num > taskCount)
    {
        cout << "\nInvalid Task Number\n";
        return;
    }

    tasks[num - 1].completed = true;

    saveTasks();

    cout << "\nTask Marked Completed\n";
}

void deleteTask()
{
    int num;

    viewTasks();

    cout << "\nEnter Task Number To Delete: ";
    cin >> num;

    if(num < 1 || num > taskCount)
    {
        cout << "\nInvalid Task Number\n";
        return;
    }

    for(int i = num - 1; i < taskCount - 1; i++)
    {
        tasks[i] = tasks[i + 1];
    }

    taskCount--;

    saveTasks();

    cout << "\nTask Deleted Successfully\n";
}

void showProgress()
{
    if(taskCount == 0)
    {
        cout << "\nNo Tasks Available\n";
        return;
    }

    int completed = 0;

    for(int i = 0; i < taskCount; i++)
    {
        if(tasks[i].completed)
            completed++;
    }

    double progress = (double)completed * 100 / taskCount;

    cout << "\n========== PROGRESS REPORT ==========\n";
    cout << "Total Tasks : " << taskCount << endl;
    cout << "Completed Tasks : " << completed << endl;
    cout << "Pending Tasks : " << taskCount - completed << endl;
    cout << "Progress : " << progress << "%" << endl;
}

int main()
{
    loadTasks();

    int choice;

    do
    {
        cout << "\n\n===== SMART STUDY PLANNER =====\n";
        cout << "1. Add Task\n";
        cout << "2. View Tasks\n";
        cout << "3. Mark Task Completed\n";
        cout << "4. Delete Task\n";
        cout << "5. Show Progress\n";
        cout << "6. Exit\n";
        cout << "Enter Choice: ";

        cin >> choice;

        switch(choice)
        {
            case 1:
                addTask();
                break;

            case 2:
                viewTasks();
                break;

            case 3:
                markCompleted();
                break;

            case 4:
                deleteTask();
                break;

            case 5:
                showProgress();
                break;

            case 6:
                cout << "\nThank You For Using Smart Study Planner\n";
                break;

            default:
                cout << "\nInvalid Choice\n";
        }

    } while(choice != 6);

    return 0;
}